# === Credenciales del bot (Discord Developer Portal) ===
# https://discord.com/developers/applications -> Tu app -> Bot -> Reset Token
DISCORD_TOKEN=pega_aqui_el_token_del_bot

# Application ID (General Information -> Application ID)
CLIENT_ID=pega_aqui_el_application_id

# ID de tu servidor "El servidor de Badtz"
# (Activa Modo Desarrollador en Discord -> clic derecho al servidor -> Copiar ID del servidor)
GUILD_ID=pega_aqui_el_id_del_servidor

# === Funciones opcionales ===
# Canal de voz donde el bot se queda 24/7 para "mantener la sala abierta" (ID del canal de voz Lounge)
VOICE_24_7_CHANNEL_ID=

# Canal "Crear sala": cuando alguien entra aquí, el bot le crea una sala temporal
JOIN_TO_CREATE_CHANNEL_ID=

# Canal de texto donde se mandan los recordatorios de racha
STREAK_REMINDER_CHANNEL_ID=

# Hora del recordatorio diario (formato cron, zona horaria abajo). Por defecto 8:00 PM.
STREAK_REMINDER_CRON=0 20 * * *

# Zona horaria (Puerto Rico)
TZ=America/Puerto_Rico

# Rol (ID) al que se le hace ping en el recordatorio. Vacío = @here
STREAK_REMINDER_ROLE_ID=

# === Asistente de voz con IA (opcional) ===
ANTHROPIC_API_KEY=
GROQ_API_KEY=
BRAIN_MODEL=claude-haiku-4-5
TTS_VOICE=es-MX-JorgeNeural
